# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# FireCrawl API Configuration
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# LangSmith Configuration (Optional - for observability and monitoring)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=math-content-generator

# Optional: Default Model Selection
# MODEL=gemini-pro

# Instructions:
# 1. Replace 'your_google_api_key_here' with your actual Google API key
# 2. Get your API key from: https://makersuite.google.com/app/apikey
# 3. Replace Supabase URL and KEY with your project credentials
# 4. Get Supabase credentials from: https://app.supabase.com/project/_/settings/api
# 5. Replace 'your_firecrawl_api_key_here' with your actual FireCrawl API key
# 6. Get FireCrawl API key from: https://firecrawl.dev/
# 7. For LangSmith: Set LANGSMITH_TRACING=true and add your API key from https://smith.langchain.com
# 8. Never commit this file to version control
# 9. Add .env to your .gitignore file
